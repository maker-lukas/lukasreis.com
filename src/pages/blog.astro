---
import BlogGrid from '../components/BlogGrid.astro';
import Layout from '../layouts/Layout.astro';
---

<Layout title="lukas/blog">
	<div class="page-grid">
		<div class="card blogs-grid">
            <h1>Blog</h1>
			<BlogGrid />
		</div>
	</div>
</Layout>

<style>
	.page-grid {
		display: grid;
		grid-template-columns: 1fr;
		grid-template-rows: 100vh;
		width: 100%;
	}

	.blogs-grid {
		display: grid;
		grid-template-columns: 1fr;
		grid-template-rows: 43px repeat(3, 130px);
		grid-gap: 15px;
	}

    .card {
        background-color: #8B5FBF;
        border-radius: 20px;
        padding: 15px;
        height: auto;
		align-self: center;
        text-align: center;
	}

	h1 {
        display: flex;
        justify-content: center;
        align-items: center;
	}
</style>