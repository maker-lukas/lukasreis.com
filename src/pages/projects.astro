---
import Layout from "../layouts/Layout.astro";
import ProjectsGrid from "../components/ProjectsGrid.astro";
---

<Layout title="lukas/projecs">
	<div class="page-grid">
		<div class="card projects-grid">
			<ProjectsGrid />
		</div>
	</div>
</Layout>

<style>
	.page-grid {
		display: grid;
		grid-template-columns: 1fr;
		grid-template-rows: 100vh;
		width: 100%;
	}

	.projects-grid {
		display: grid;
		grid-template-columns: 1fr 1fr 1fr;
		grid-template-rows: 60px 1fr 1fr;
		grid-gap: 15px;
	}

    .card {
        background-color: #8B5FBF;
        border-radius: 20px;
        padding: 15px;
        height: 700px;
		align-self: center;
	}
</style>