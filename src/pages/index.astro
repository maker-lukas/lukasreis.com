---
import Layout from "../layouts/Layout.astro";
import Intro from "../components/Intro.astro"
import Projects from "../components/Projects.astro";
import BlogHome from "../components/BlogHome.astro"
---

<Layout title="lukas/home">
    <div class="page-grid">
        <div class="item item-1 intro-grid">
            <Intro />
        </div>    
        <div class="item item-2 projects-grid">
           <Projects />
        </div>
        <div class="item item-3 blog-grid">
            <BlogHome />
        </div>
    </div>
</Layout>

<style>
    .page-grid {
        display: grid;
        grid-template-columns: 1fr;
        grid-template-rows: repeat(3, 100vh);
        width: 100%;
    }

    .intro-grid {
        display: grid;
        grid-template-columns: 2fr 1fr;
        grid-template-rows: auto auto;
        grid-template-areas:
            "one two"
            "one three";
        gap: 15px;
    }

    .projects-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        grid-template-rows: 43px auto;
        grid-gap: 15px;
    }

    .blog-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        grid-template-rows: 43px auto auto auto;
        gap: 15px;
    }
    
    .item {
        width: 100%;
        background-color: #8B5FBF;
        border-radius: 20px;
        padding: 15px;
        height: 450px;
    }

    .item-1 {
        place-self: center;
    }

    .item-2 {

    }

    .item-3 {
        font-size: 32px;
        font-weight: bold;
        text-align: center;
    }

    h1 {
        font-size: 32px;
    }
</style>
