---
import Layout from "../layouts/Layout.astro";
import Intro from "../components/Intro.astro"
import BlogHome from "../components/BlogHome.astro"
import ProjectsHome from "../components/ProjectsHome.astro";
import Link from "../components/Link.astro";
---

<Layout title="lukas/home">
    <div class="page-grid">
        <div class="card card1 intro-grid">
            <Intro />
        </div>    
        <div class="card projects-grid">
           <ProjectsHome />
        </div>
		<div class="card blogs-grid">
            <div class="link">
                <span></span>
                <h1>Blog</h1>
                <Link page="/blog" text="see more →">
            </div>
			<BlogHome />
		</div>
    </div>
</Layout>

<style>

    .page-grid {
        display: grid;
        grid-template-columns: 1fr;
        grid-template-rows: repeat(3, 100vh);
        width: 100%;
        
    }

    .intro-grid {
        display: grid;
        grid-template-columns: 2fr 1fr;
        grid-template-rows: auto auto;
        grid-template-areas:
            "one two"
            "one three";
        gap: 15px;
        height: 450px;
    }

    .projects-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        grid-template-rows: 43px auto;
        grid-gap: 15px;
        height: 450px;
    }

    .blogs-grid {
		display: grid;
		grid-template-columns: 1fr;
		grid-template-rows: 43px repeat(3, 130px);
		grid-gap: 15px;
        text-align: center;
        height: 508px;
	}
    
    .card {
        width: 100%;
        background-color: #8B5FBF;
        border-radius: 20px;
        padding: 15px;
        align-self: center;
    }

    h1 {
        font-size: 32px;
    }

    .link {
        display: grid;
        grid-template-columns: auto auto auto;
        
    }

    @media (max-width: 700px) {
        .link {
            visibility: hidden;
        }

        .card {
            width: 100%;
            padding: 15px;
        }


        .blogs-grid {
            height: 450px;
        }

        .intro-grid {
            grid-template-columns: 1fr;
            grid-template-rows: auto auto;
            grid-template-areas:
                "one"
                "two";
            height: 450px;
        }

        .projects-grid {
            grid-template-columns: repeat(3, 1fr);
            grid-template-rows: 35px auto auto;
        }

    }
</style>
