---
import type { CollectionEntry } from 'astro:content';

import FormattedDate from '../components/FarmattedDate.astro';

import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

type Props = CollectionEntry<'blog'>['data'];
const { title, description, pubDate } = Astro.props;
const id = Astro.url.pathname.split('/').pop();


---
<!DOCTYPE html>
<html lang="en">
<head>
	<meta charset="utf-8" />
	<meta name="viewport" content="width=device-width" />
	<title>lukas/blog/{id}</title>
</head>
<body>
    <Header />
    <main>
        <div class="page-grid">
            <div class="card">
                <div class="frontmatter">
                    <h1>{title}</h1>
                    <p>{description}</p>
                    <p>
                        <FormattedDate date={pubDate} />
                    </p>
                </div>
                <slot />
            </div>
        </div>
    </main>
    <Footer />
</body>
</html>

<style>
    .frontmatter {
        text-align: center;
        background-color: #7550A1;
        border-radius: 10px;
        padding: 15px;
        margin-bottom: 15px;
    }

	.page-grid {
		display: grid;
		place-items: center;
		padding-top: 100px;
		padding-bottom: 50px;
		min-height: 100vh;
	}

    .card {
        background-color: #8B5FBF;
        border-radius: 20px;
        padding: 15px;
        height: auto;
        width: 100%;
    }

    h1 {
        font-size: 32px;
    }
    
    :global(pre) {
        background-color:#171717 !important;
        padding: 15px;
        border-radius: 10px;
        overflow-x: auto;
        margin-top: 15px;
    }

    :global(code) {
        font-size: 14px;
    }

    :global(p) {
    margin-bottom: 15px;
    line-height: 1.6;
}

    :global(ol),
    :global(ul) {
        margin-left: 20px;
        margin-bottom: 15px;
    }

    :global(li) {
        margin-bottom: 8px;
        line-height: 1.6;
    }

    :global(img) {
        max-width: 100%;
        border-radius: 10px;
    }

</style>