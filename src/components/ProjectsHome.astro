---
import Link from "./Link.astro";
---

<div class="inner inner-1"></div>
<div class="inner inner-2">
    <h1>Projects</h1>
</div>
<div class="inner inner-3">
    <Link page="/projects" />
</div>
<div class="inner project">1</div>
<div class="inner project">2</div>
<div class="inner project">3</div>

<style>

    .inner {
        border-radius: 10px;
    }

    .inner-2 {
        text-align: center;
    }

    .inner-3 {
        text-align: end;
        margin-top: auto;
        margin-bottom: auto;
    }

    .project {
        padding: 15px;
        background-color: #7550A1;
    }

    h1 {
        font-size: 32px;
        font-weight: bold;
    }
</style>