<div class="footer-nav">
    <nav class="nav">
        <a href="/">Home</a>
        <span> / </span>
        <a href="/blog">Blog</a>
        <span> / </span>
        <a href="/projects">Projects</a>
    </nav>
    
    <footer>
        <p>
            Made with <span>&lt;3</span> by Lukas using
            <a href="https://astro.build">Astro</a>
        </p>
        <div>
            <a href="https://www.gnu.org/licenses/agpl-3.0.en.html">AGPL-3.0</a>
            <p>
                Source at
                <a href="https://github.com/maker-lukas/lukasreis.com">GitHub</a>
            </p>
        </div>
    </footer>
</div>

<style>
    a {
        color: #171717;
    }

    span {
        color: #171717;
    }

    .footer-nav {
        position: fixed;
        bottom: 0;
        inset-inline: 0;
        background-color: #ECD444;
        border-radius: 20px 20px 0px 0px;
        margin-inline: max(calc((100% - 810px) / 2), 15px);
        z-index: 100;
        
        display: none;
        flex-direction: column;
        
        font-weight: bold;
        font-size: 20px;
    }

    .nav {
        display: flex;
        align-items: center;
        justify-content: center;
        height: 50px;
        padding-inline: 15px;
        gap: 10px;
    }

    footer {
        padding: 15px;
        text-align: center;
        border-top: 2px solid #171717;
    }

    footer p {
        font-weight: bold;
        font-size: 16px;
        color: #171717;
        margin: 0;
    }

    footer a {
        font-size: 16px;
    }

    footer a:link {
        text-decoration: underline;
    }

    footer a:active,
    footer a:hover {
        text-decoration: none;
    }

    @media (max-width: 700px) {
        .footer-nav {
            display: flex;
        }
    }
</style>

<script>
    const footerNav = document.querySelector('.footer-nav') as HTMLElement;
    const footerContent = document.querySelector('.footer-nav footer') as HTMLElement;
    
    if (footerNav && footerContent) {
        function updateFooterVisibility() {
            const scrollPercentage = (window.scrollY + window.innerHeight) / document.documentElement.scrollHeight;
            
            // Show footer content only at the very end of page
            if (scrollPercentage > 0.98) {
                footerContent.style.display = 'block';
            } else {
                footerContent.style.display = 'none';
            }
        }
        
        window.addEventListener('scroll', updateFooterVisibility);
        updateFooterVisibility();
    }
</script>
