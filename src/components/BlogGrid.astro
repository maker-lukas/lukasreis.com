---
import { getCollection } from 'astro:content';
import FormattedDate from '../components/FarmattedDate.astro';

const posts = (await getCollection('blog'))
    .filter(post => !post.data.draft)
    .sort(
        (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
    );
---

{posts.length === 0 && <p class="empty">No posts yet :(</p>}

{posts.map((post) => (
    <div class="post-card">
        <span></span>
        <div class="data">
            <div>
                <h1 class="title">{post.data.title}</h1>
                <p class="description">{post.data.description}</p>
            </div>
            <p class="meta">
                Published on <FormattedDate date={post.data.pubDate} />
            </p>
        </div>
        <div class="read-post">
            <a href={`/blog/${post.id}`}>Read Post →</a>
        </div>
    </div>
))}

<style>
    .data {
        display: flex;
        flex-direction: column;
        justify-content: space-between;
    }

    .post-card {
        background-color:#7550A1;
        border-radius: 10px;
        padding: 15px;
        display: grid;
        grid-template-columns: 1fr auto 1fr;
    
        /* &:not(:first-child) {
            margin-top: 15px;
        } */
    }

    a {
        font-size: 18px;
        font-weight: bold;
        color: white;
    }

    h1 {
        font-size: 20px;
    }

    .read-post {
        text-align: end;
    }

    @media (max-width: 700px) {
        .post-card {
            display: flex;
            flex-direction: column;
            justify-content: space-between;
            padding: 15px 15px 10px 15px;
        }

        .data {
            margin: 10px 0;
        }

        .read-post {
            text-align: center;
            margin-top: auto;
        }

        .title {
            font-size: 18px;
            margin: 5px 0;
        }

        .meta {
            font-size: 15px;
            margin: 5px 0;
        }

        .description {
            font-size: 15px;
            margin: 5px 0;
        }
    }

</style>
