<span class="age">loading…</span>

<script>
  const el = document.currentScript.previousElementSibling;

  const birthMs = Date.parse("1998-04-17T18:42:00Z");
  const SECONDS_PER_YEAR = 31556925.216;

  function updateAge() {
    const secondsLived = (Date.now() - birthMs) / 1000;
    el.textContent =
      (secondsLived / SECONDS_PER_YEAR).toFixed(6);
  }

  updateAge();
  setInterval(updateAge, 1000);
</script>
