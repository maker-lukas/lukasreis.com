---
import { getCollection } from 'astro:content';
import FormattedDate from '../components/FarmattedDate.astro';

const allPosts = (await getCollection('blog'))
    .filter(post => !post.data.draft)
    .sort(
        (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
    );
const posts = allPosts.slice(0, 3);
---

{posts.length === 0 && <p class="empty">No posts yet :(</p>}

{posts.map((post, index) => (
    <div class="post-card" data-index={index}>
        <span></span>
        <div class="data">
            <div>
                <h1>{post.data.title}</h1>
                <p class="description">{post.data.description}</p>
            </div>
            <p class="meta">
                Published on <FormattedDate date={post.data.pubDate} />
                <a href={`/blog/${post.id}`} class="mobile-read"><span class="desktop">Read Post →</span><span class="mobile">Read →</span></a>
            </p>
        </div>
        <div class="read-post">
            <a href={`/blog/${post.id}`}><span class="desktop">Read Post →</span><span class="mobile">Read →</span></a>
        </div>
    </div>
))}

<style>
    .data {
        display: flex;
        flex-direction: column;
        justify-content: space-between;
    }

    .post-card {
        background-color:#7550A1;
        border-radius: 10px;
        padding: 15px;
        display: grid;
        grid-template-columns: 1fr auto 1fr;
    }
    

    a {
        font-size: 18px;
        font-weight: bold;
        color: white;
        width: fit-content;
    }

    .desktop,
    .mobile {
        display: inline;
        line-height: 1;
        vertical-align: baseline;
    }

    .mobile {
        display: none;
    }

    .mobile-read {
        display: none;
        margin-top: 8px;
    }

    h1 {
        font-size: 20px;
    }

    .read-post {
        text-align: end;
        width: fit-content;
        justify-self: end;
    }

    @media (max-width: 700px) {
        .post-card[data-index="2"] {
            display: none;
        }

        .desktop {
            display: none;
        }

        .mobile {
            display: inline;
        }

        .mobile-read {
            display: block;
            width: fit-content;
            margin: 8px auto 0 auto;
        }

        h1 {
            font-size: 17px;
        }

        p {
            font-size: 14px;
        }

        .read-post {
            display: none;
        }
    }
</style>
