---

const { showImage } = Astro.props

---

<div class="container">
    <div>
        <img
        src="../images/keyboard.jpg"
        alt="40%ish split keyboard"
        style={`display: ${showImage ? 'block' : 'none'}`}/>
        <h1>40%ish Split Keyboard</h1>
        <p>A fully custom 36 key wired split keyboard</p>
    </div>

    <a href="https://github.com/maker-lukas/40-ish-split-keyboard">GitHub</a>
</div>

<style>
    img {
        width: 100%;
        display: {imageShow};
        margin-inline: auto;
        border-radius: 10px;
    }

    h1 {
        font-size: 15px;
        text-align: center;
        margin-top: 15px;
    }

    p {
        margin-top: 5px;
        font-size: 14px;
        text-align: center;
    }

    .container {
        display: flex;
        flex-direction: column;
        justify-content: space-between;
        height: 100%;
        align-items: center;
    }

    a {
        color: white;
        font-weight: bold;
    }

    @media (max-width: 700px) {
        img {
            display: {imageShow};
        }
    }
</style>