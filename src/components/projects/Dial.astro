---

const { showImage, isHomepage } = Astro.props

---

<div class="container">
    <div>
         <img
         src="../images/dial.png"
         alt="Dial"
         class={isHomepage ? 'homepage' : ''}
         />
        <h1>Dial</h1>
        <p>A wireless smooth scrolling dial that uses a AS5600 sensor</p>
    </div>

    <a href="https://github.com/maker-lukas/Scroll-Dial">GitHub</a>
</div>

<style>
    img {
         width: 100%;
         display: block;
         margin-inline: auto;
         border-radius: 10px;
     }

    h1 {
        font-size: 15px;
        text-align: center;
        margin-top: 15px;
    }

    p {
        margin-top: 5px;
        font-size: 14px;
        text-align: center;
    }

    .container {
        display: flex;
        flex-direction: column;
        justify-content: space-between;
        height: 100%;
        align-items: center;
    }

    a {
        color: white;
        font-weight: bold;
    }

    @media (max-width: 700px) {
         img.homepage {
             display: none;
         }
     }
</style>