---
import Age from "./Age.astro";


---

<div class="inner inner-1">
    <div class="intro">
        <h1>Hya! I'm Lukas.</h1>
        <p class="age">A 16 y/o human</p>
        <p class="about">About:</p>
        <p class="text">A tech nerd, hardware enthusiast, programming noob.</p>
        
    </div>
    <a href="https://hackclub.com/"><img style="width: 170px;" src="https://assets.hackclub.com/flag-orpheus-left.svg" alt="Hack Club"/></a>
</div>
<div class="inner inner-2">
    <img class="image"
    src="../images/lukas.jpg"
    alt="picture of lukas"/>
    <div class="stats">
        <div id="utc-clock">--:--:-- --</div>
        <span>/</span>
        <p>status</p>
    </div>
</div>
<div class="inner inner-3">
    Now Playing
</div>

<style>
    .inner {
        background-color: #7550A1;
        border-radius: 10px;
    }

    .inner-1 {
        grid-area: one;
        height: 100%;
        background-color:#8B5FBF;

        display: flex;
        flex-direction: column;
        justify-content: space-between;
    }

    .inner-2 {
        grid-area: two;
        height: 295px;
        padding: 15px 15px 10px 15px;

        display: flex;
        flex-direction: column;
        justify-content: space-between;
    }

    .inner-3 {
        grid-area: three;
        height: 110px;
        padding: 15px;

    }

    .image {
    width: 100%;
    display: block;
    margin-inline: auto;
    border-radius: 10px;
    }

    .age {
        margin-top: 10px;
        font-size: 20px;
        font-weight: bold;
        margin-bottom: 20px;
    }

    .stats {
        display: flex;
        align-items: center;
        justify-content: space-between;

        color: #171717;
        background-color: #ECD444;
        width: 100%;
        height: 30px;
        border-radius: 15px;

        font-size: 14px;
        font-weight: bold;
        padding-inline: 15px;
    }

    .about {
        font-size: 20px;
        font-weight: bold;
    }

    .text {
        font-size: 20px;
    }

    .intro {
        padding-left: 15px;
    }

</style>

<script is:inline>
    function updateClock() {
        const zdt = Temporal.Now.instant().toZonedDateTimeISO("UTC");

        let hours = zdt.hour;
        const minutes = zdt.minute.toString().padStart(2, "0");
        const seconds = zdt.second.toString().padStart(2, "0");

        const ampm = hours >= 12 ? "pm" : "am";
        hours = hours % 12 || 12;

        document.getElementById("utc-clock").textContent =
        `${hours}:${minutes}:${seconds} ${ampm}`;
    }

    updateClock();
    setInterval(updateClock, 1000);
</script>